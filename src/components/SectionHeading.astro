---
import type { LocalizedText } from '../data/site';

interface Props {
	label: LocalizedText;
	intro?: string;
}

const { label, intro } = Astro.props;
---

<header class="section-heading">
	<p class="section-heading__label">
		<span>{label.en}</span>
		{label.ja && <span class="section-heading__label-ja">{label.ja}</span>}
	</p>
	{intro && <p class="section-heading__intro">{intro}</p>}
</header>

---
import type { Project } from '../data/site';

interface Props {
	project: Project;
}

const { project } = Astro.props;
---

<article class="project-card reveal">
	<div class="project-card__meta">
		<p class="project-card__category">{project.category}</p>
		<p class="project-card__status">{project.status}</p>
	</div>
	<h3>{project.name}</h3>
	<p class="project-card__summary">{project.summary}</p>
	<div class="project-card__body">
		<p>
			<strong>Problem</strong>
			{project.problem}
		</p>
		<p>
			<strong>Built</strong>
			{project.solution}
		</p>
	</div>
	<ul class="project-card__stack" aria-label={`${project.name} stack`}>
		{
			project.stack.map((item) => (
				<li>{item}</li>
			))
		}
	</ul>
	<div class="project-card__links">
		<a href={project.repoUrl} target="_blank" rel="noreferrer">Repository</a>
		{
			project.liveUrl && (
				<a href={project.liveUrl} target="_blank" rel="noreferrer">
					Live Demo
				</a>
			)
		}
	</div>
</article>

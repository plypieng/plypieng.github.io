---
import BaseLayout from '../layouts/BaseLayout.astro';
import { contactLinks, copy, focusAreas, profile, projects, timeline } from '../data/site';

const projectOrder = [
	'rouvis-web',
	'interactive-torque-project',
	'ceramic-fracture-lab',
	'firebase-esp32-ctmonitor',
];
const featuredProjects = projectOrder
	.map((slug) => projects.find((project) => project.slug === slug))
	.filter((project): project is (typeof projects)[number] => project !== undefined);
const timelineItems = [...timeline].reverse();
const visibleContactLinks = contactLinks.filter((link) => link.label !== 'Company context');
const primaryLinks = [
	{ label: 'GitHub', href: profile.github },
	{ label: 'LinkedIn', href: profile.linkedin },
	{ label: 'Email', href: `mailto:${profile.email}` },
];
---

<BaseLayout title={copy.pageTitle} description={copy.pageDescription}>
	<main class="container">
		<header class="profile-header">
			<a class="profile-photo" href="/" aria-label="Homepage">
				<img
					src="/images/profile.jpg"
					alt="Portrait of Nantaphon Chimpalee"
					width="1280"
					height="1269"
					loading="eager"
				/>
			</a>

			<div class="profile-summary">
				<h1>{profile.name}</h1>
				<p>{profile.title}</p>
				<p>{profile.company}</p>
				<p>{profile.location}</p>
				<p>
					{
						primaryLinks.map((link, index) => (
							<>
								<a href={link.href} target={link.href.startsWith('http') ? '_blank' : undefined} rel={link.href.startsWith('http') ? 'noreferrer' : undefined}>
									{link.label}
								</a>
								{index < primaryLinks.length - 1 && <span> / </span>}
							</>
						))
					}
				</p>
			</div>
		</header>

		<nav class="site-nav" aria-label="Page sections">
			<a href="#bio">Bio</a>
			<a href="#research">Research Interests</a>
			<a href="#work">Selected Work</a>
			<a href="#experience">Experience</a>
			<a href="#personal">Personal</a>
			<a href="#contact">Contact</a>
		</nav>

		<section class="docs-section" id="bio">
			<h2>Bio</h2>
			<p>
				I am a fourth-year B.Eng. student at Nagaoka University of Technology.
				My work connects <strong>machine learning</strong>, <strong>industrial sensing</strong>,
				<strong>embedded systems</strong>, and <strong>software prototypes</strong>.
			</p>
			<p>
				Before university, I worked at Kuroda Precision in Japanese manufacturing. I started in process
				development, then transferred into AIoT because of my AI and embedded systems skills, building data
				collection and quality-analysis workflows around real sensors and production constraints. That
				background shapes my current interest in AI systems that are practical, inspectable, and useful outside
				controlled demos.
			</p>
			<p>
				My recent projects include vertical AI product work, manufacturing data-analysis tools,
				automotive hardware architecture exposure, and simulation prototypes for technical
				experimentation.
			</p>
		</section>

		<section class="docs-section" id="research">
			<h2>Research Interests</h2>
			<ul class="plain-list">
				{
					focusAreas.map((area) => (
						<li>
							<strong>{area.title}.</strong> {area.description}
						</li>
					))
				}
			</ul>
		</section>

		<section class="docs-section" id="work">
			<h2>Selected Work</h2>
			{
				featuredProjects.map((project) => (
					<article class="work-entry">
						<p class="work-title">
							<strong>{project.name}</strong>
							<span> {project.category}</span>
						</p>
						<p>{project.summary}</p>
						<p>
							<em>{project.status}</em>
						</p>
						<p class="work-links">
							<a href={project.repoUrl} target="_blank" rel="noreferrer">Code</a>
							{project.liveUrl && (
								<>
									<span> / </span>
									<a href={project.liveUrl} target="_blank" rel="noreferrer">Demo</a>
								</>
							)}
							{project.recognitionUrl && (
								<>
									<span> / </span>
									<a href={project.recognitionUrl} target="_blank" rel="noreferrer">
										{project.recognitionLabel ?? 'Recognition'}
									</a>
								</>
							)}
						</p>
					</article>
				))
			}
		</section>

		<section class="docs-section" id="experience">
			<h2>Experience</h2>
			<ul class="timeline-list">
				{
					timelineItems.map((item, index) => (
						<li class={`timeline-item timeline-item--${index % 2 === 0 ? 'left' : 'right'}`}>
							<div class="timeline-node" aria-hidden="true"></div>
							<div class="timeline-card">
								<div class="timeline-heading">
									<span class="timeline-time">{item.dateRange}</span>
									<strong>{item.label}</strong>
								</div>
								<p>{item.detail}</p>
							</div>
						</li>
					))
				}
			</ul>
		</section>

		<section class="docs-section" id="personal">
			<h2>Personal</h2>
			<p>
				Outside engineering, I enjoy games like Dota 2, espresso, and long-distance running. I have
				completed several full marathons in Japan.
			</p>
			<ul class="plain-list compact-list">
				<li><strong>Languages.</strong> Thai (native), English (C2), Japanese (JLPT N1).</li>
			</ul>
		</section>

		<section class="docs-section" id="contact">
			<h2>Contact</h2>
			<p>
				For research, internship, engineering, or collaboration inquiries, email is the best contact path.
			</p>
			<ul class="contact-list">
				{
					visibleContactLinks.map((link) => (
						<li>
							<a href={link.href} target={link.href.startsWith('http') ? '_blank' : undefined} rel={link.href.startsWith('http') ? 'noreferrer' : undefined}>
								{link.label}
							</a>
							<span> - {link.note}</span>
						</li>
					))
				}
			</ul>
		</section>

		<footer class="footer">
			<p>{profile.name} / {profile.email}</p>
		</footer>
	</main>
</BaseLayout>
